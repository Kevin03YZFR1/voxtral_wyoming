# Voxtral Wyoming STT - Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Server Configuration
# ============================================================================

# Bind host (default: 0.0.0.0)
# Use 0.0.0.0 to listen on all interfaces, or 127.0.0.1 for localhost only
HOST=0.0.0.0

# Bind port (default: 10300)
# Wyoming protocol default port for STT services
PORT=10300

# Language/locale hint (default: en-US)
# This is just a fallback and will get overridden by the configuration of your Home Assistant Voice Assistant.
#
# Voxtral supports the following 8 languages:
#   - en-US (English)
#   - fr-FR (French)
#   - de-DE (German)
#   - es-ES (Spanish)
#   - it-IT (Italian)
#   - pt-PT (Portuguese)
#   - nl-NL (Dutch)
#   - hi-IN (Hindi)
#
# Furthermore, Voxtral theoretically supports multilingual usage by automatically determining the spoken language.
# However, Home Assistant does not seem to support this yet.
LANGUAGE_FALLBACK=en-US

# Expected audio sample rate in Hz (default: 16000)
# Common values: 8000, 16000, 22050, 24000, 32000, 48000
# Again just a fallback value which will get replaced by the information which Home Assistant provides through the Wyoming protocol.
SAMPLE_RATE_FALLBACK=16000

# Maximum audio duration in seconds (default: 60)
# Audio longer than this will be clamped for safety
MAX_SECONDS=60

# Logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Model Configuration
# ============================================================================

# Voxtral model ID (default: mistralai/Voxtral-Mini-3B-2507)
# Options:
#   - mistralai/Voxtral-Mini-3B-2507 (smaller, faster)
#   - mistralai/Voxtral-Small-24B-2507 (larger, more accurate)
#   - /models/Voxtral-Mini-3B-2507 (local path, if mounted)
MODEL_ID=mistralai/Voxtral-Mini-3B-2507

# Device for inference (default: cuda)
# Options: cpu, cuda (NVIDIA GPU), mps (Apple Silicon)
# Note: Automatically falls back to CPU if the specified device is unavailable
DEVICE=cuda

# Data type for model weights (default: bf16)
# Options: fp32 (full precision), fp16 (half precision), bf16 (bfloat16)
# Note: CPU always uses fp32 regardless of this setting for stability
#
# Trade-offs between data types:
#
# fp32 (float32) - Full Precision:
#   ✓ Best accuracy and numerical stability
#   ✓ Works on all devices (CPU, CUDA, MPS)
#   ✓ Recommended for CPU inference
#   ✗ Highest memory usage (~12GB VRAM for Mini, ~48GB for Small)
#   ✗ Slowest inference speed on GPU
#
# bf16 (bfloat16) - Brain Float 16:
#   ✓ Excellent balance of speed, memory, and accuracy
#   ✓ ~50% memory reduction vs fp32 (~6GB VRAM for Mini, ~24GB for Small)
#   ✓ 1.5-2x faster inference than fp32 on modern GPUs
#   ✓ Better numerical stability than fp16 (wider dynamic range)
#   ✓ Minimal accuracy loss for most STT tasks
#   ✓ Recommended for GPU inference (especially NVIDIA Ampere/Ada or newer)
#   ✗ Requires GPU with bfloat16 support (Ampere A100/RTX 30xx+, or Apple M1+)
#
# fp16 (float16) - Half Precision:
#   ✓ ~50% memory reduction vs fp32 (same as bf16)
#   ✓ 1.5-2x faster inference than fp32 on GPU
#   ✓ Wider GPU compatibility than bf16
#   ✗ Can have numerical instability issues (narrower dynamic range)
#   ✗ May produce lower quality transcriptions than bf16 in some cases
#   ⚠ Consider using bf16 instead if your GPU supports it
#
# Recommendations:
# - CPU: Keep fp32 (automatically enforced)
# - Modern NVIDIA GPU (RTX 30xx/40xx, A100, H100): Use bf16 for best balance
# - Older NVIDIA GPU (RTX 20xx, V100, P100): Use fp16 or fp32
# - Apple Silicon (M1/M2/M3): Use bf16 if supported, otherwise fp32
# - Limited VRAM: Try bf16 or fp16 to fit larger models
# - Maximum accuracy needed: Use fp32 (at cost of speed and memory)
DATA_TYPE=bf16

# Maximum number of new tokens to generate (default: 128)
# Higher values allow longer transcriptions but increase processing time
MAX_NEW_TOKENS=128

# ============================================================================
# Transcription Mode Configuration
# ============================================================================

# Use chat mode instead of transcribe-only mode (default: false)
# Turn this on only if you're not satisfied by the results of the default
# transcribe-only mode and want to try out enhancing the accuracy by using
# a system prompt (see SYSTEM_PROMPT env).
USE_CHAT_MODE=false

# System prompt for chat mode (only used when USE_CHAT_MODE=true)
# This prompt provides context to guide the model's transcription behavior.
# Default prompt emphasizes smart home commands and imperative sentences.
SYSTEM_PROMPT="You are a voice assistant for a smart home. Transcribe the user's voice command accurately. Commands are typically short, imperative sentences like 'turn on the lights' or 'set temperature to 20 degrees'. Focus on accuracy and be aware of smart home terminology."

# ============================================================================
# Audio Saving Configuration
# ============================================================================

# Enable saving of received audio input (default: false)
# When enabled, creates one WAV file per transcription request
# Options: true, false
# WARNING: Audio files may contain sensitive information. Ensure proper access controls.
SAVE_AUDIO=false

# Directory where audio files will be saved (default: /output/audio)
# The directory will be created automatically if it doesn't exist
# Each file is named with a timestamp and the first 100 characters of the transcribed text:
#   audio_YYYYMMDD_HHMMSS_microseconds_transcribed_text.wav
# Special characters in the transcription are replaced with underscores for filesystem safety
#
# Docker: Use absolute path /output/audio (matches volume mount in docker-compose.yml)
# Non-Docker: Use relative path ./output/audio/ or any writable directory path
AUDIO_SAVE_DIR=/output/audio
